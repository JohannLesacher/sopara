{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "1560px",
      "wideSize": "1600px"
    },
    "background": {
      "backgroundImage": true
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },
    "color": {
      "custom": true,
      "customGradient": true,
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "link": true,
      "palette": [
        {
          "slug": "primary-0",
          "color": "#FF0000",
          "name": "Primary 0"
        },
        {
          "slug": "primary-1",
          "color": "#FF2F2F",
          "name": "Primary 1"
        },
        {
          "slug": "primary-2",
          "color": "#FF5A5A",
          "name": "Primary 2"
        },
        {
          "slug": "primary-3",
          "color": "#FF8D8D",
          "name": "Primary 3"
        },
        {
          "slug": "primary-4",
          "color": "#FFC7C7",
          "name": "Primary 4"
        },
        {
          "slug": "secondary-0",
          "color": "#444444",
          "name": "Secondary 0"
        },
        {
          "slug": "secondary-1",
          "color": "#70706E",
          "name": "Secondary 1"
        },
        {
          "slug": "secondary-2",
          "color": "#959493",
          "name": "Secondary 2"
        },
        {
          "slug": "secondary-3",
          "color": "#CCCCD0",
          "name": "Secondary 3"
        },
        {
          "slug": "secondary-4",
          "color": "#EDEDF0",
          "name": "Secondary 4"
        },
        {
          "slug": "black",
          "color": "#000000",
          "name": "Black"
        },
        {
          "slug": "white",
          "color": "#FFFFFF",
          "name": "White"
        }
      ]
    },
    "custom": {
      "typography": {
        "font-size": {},
        "line-height": {}
      }
    },
    "spacing": {
      "padding": true,
      "margin": true,
      "blockGap": true,
      "units": [
        "px",
        "%",
        "em",
        "rem",
        "vw",
        "vh"
      ]
    },
    "typography": {
      "defaultFontSizes": false,
      "customFontSize": true,
      "lineHeight": true,
      "fluid": true,
      "fontFamilies": [
        {
          "name": "Figtree",
          "slug": "figtree",
          "fontFamily": "Figtree, sans-serif"
        },
        {
          "name": "Syncopate",
          "slug": "syncopate",
          "fontFamily": "Syncopate, sans-serif"
        }
      ],
      "fontSizes": [
        {
          "name": "Tiny",
          "slug": "tiny",
          "size": "0.75rem",
          "fluid": false
        },
        {
          "name": "Small",
          "slug": "small",
          "size": "0.875rem",
          "fluid": false
        },
        {
          "name": "Regular",
          "slug": "regular",
          "size": "1rem",
          "fluid": false
        },
        {
          "name": "Medium",
          "slug": "medium",
          "size": "1.125rem",
          "fluid": {
            "min": "0.875rem",
            "max": "1.125rem"
          }
        },
        {
          "name": "Large",
          "slug": "large",
          "size": "1.25rem",
          "fluid": {
            "min": "1rem",
            "max": "1.25rem"
          }
        },
        {
          "name": "Tagline",
          "slug": "tagline",
          "size": "1rem",
          "fluid": {
            "min": "0.75rem",
            "max": "1rem"
          }
        },
        {
          "name": "Heading 6",
          "slug": "h6",
          "size": "1.25rem",
          "fluid": {
            "min": "1.125rem",
            "max": "1.25rem"
          }
        },
        {
          "name": "Heading 5",
          "slug": "h5",
          "size": "1.5rem",
          "fluid": {
            "min": "1.25rem",
            "max": "1.5rem"
          }
        },
        {
          "name": "Heading 4",
          "slug": "h4",
          "size": "2rem",
          "fluid": {
            "min": "1.5rem",
            "max": "2rem"
          }
        },
        {
          "name": "Heading 3",
          "slug": "h3",
          "size": "2.5rem",
          "fluid": {
            "min": "2rem",
            "max": "2.5rem"
          }
        },
        {
          "name": "Heading 2",
          "slug": "h2",
          "size": "3rem",
          "fluid": {
            "min": "2.25rem",
            "max": "3rem"
          }
        },
        {
          "name": "Heading 1",
          "slug": "h1",
          "size": "3.5rem",
          "fluid": {
            "min": "2.5rem",
            "max": "3.5rem"
          }
        }
      ]
    },
    "blocks": {
      "core/group": {
        "background": {
          "backgroundImage": true,
          "backgroundSize": true
        }
      }
    }
  },
  "styles": {
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--figtree)",
      "fontSize": "var(--wp--preset--font-size--regular)"
    },
    "spacing": {
      "blockGap": "2rem"
    },
    "elements": {
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--syncopate)",
          "fontSize": "var(--wp--preset--font-size--h-1)",
          "lineHeight": "1.2",
          "textTransform": "uppercase"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--syncopate)",
          "fontSize": "var(--wp--preset--font-size--h-2)",
          "lineHeight": "1.2",
          "textTransform": "uppercase"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--figtree)",
          "fontSize": "var(--wp--preset--font-size--h-3)",
          "lineHeight": "1.2"
        }
      },
      "h4": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--syncopate)",
          "fontSize": "var(--wp--preset--font-size--h-4)",
          "lineHeight": "1.3",
          "textTransform": "uppercase"
        }
      },
      "h5": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--figtree)",
          "fontSize": "var(--wp--preset--font-size--h-5)",
          "lineHeight": "1.4"
        }
      },
      "h6": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--figtree)",
          "fontSize": "var(--wp--preset--font-size--h-6)",
          "lineHeight": "1.4"
        }
      },
      "button": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--regular)"
        }
      }
    }
  }
}
